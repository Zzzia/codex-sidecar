{
  "name": "codex-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.28.0",
  "scripts": {
    "dev": "node tools/dev.mjs",
    "dev:server": "tsx watch --clear-screen=false src/server/index.ts",
    "dev:web": "vite",
    "build": "pnpm build:web && pnpm build:server",
    "build:web": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "preview": "NODE_ENV=production node dist-server/server/index.js",
    "check": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.server.json --noEmit",
    "test": "node --test --import tsx src/**/*.test.ts"
  },
  "dependencies": {
    "@git-diff-view/file": "0.0.30",
    "@git-diff-view/react": "0.0.30",
    "clsx": "2.0.0",
    "lucide-react": "0.539.0",
    "mermaid": "11.13.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-markdown": "9.1.0",
    "react-resizable-panels": "4.0.13",
    "react-virtuoso": "4.14.0",
    "rehype-highlight": "7.0.2",
    "rehype-raw": "7.0.0",
    "rehype-sanitize": "6.0.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "4.0.1"
  },
  "devDependencies": {
    "@types/node": "24.10.1",
    "@types/react": "18.3.23",
    "@types/react-dom": "18.3.7",
    "@vitejs/plugin-react": "4.5.2",
    "tsx": "4.21.0",
    "typescript": "5.9.2",
    "vite": "7.3.1"
  }
}
